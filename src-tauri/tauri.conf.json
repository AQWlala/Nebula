{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "nebula",
  "mainBinaryName": "nebula",
  "version": "2.0.0",
  "identifier": "com.nebula.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nebula",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' '${TAURI_NONCE}'; script-src 'self' '${TAURI_NONCE}'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:11434 https://*.ollama.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Nebula — AI 知识星云",
    "longDescription": "A local-first AI assistant that evolves with your knowledge. Your memory, your intelligence.",
    "publisher": "AQWlala",
    "homepage": "https://github.com/AQWlala/nebula",
    "fileAssociations": [
      { "ext": ["md"], "name": "Markdown", "description": "Markdown 文档" },
      { "ext": ["txt"], "name": "Plain Text", "description": "纯文本文件" },
      { "ext": ["nebula"], "name": "Nebula Project", "description": "Nebula 项目文件" },
      { "ext": ["nmemory"], "name": "Nebula Memory Export", "description": "Nebula 记忆导出" }
    ]
  },
  "plugins": {
    "globalShortcut": {
      "shortcut": "CmdOrCtrl+Shift+H"
    },
    "updater": {
      "pubkey": "vl2AY5Eme9dkHDZG0e/4e+cFmuk/41zgGH9LCAmflVc="
    },
    "autostart": null
  }
}
