# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Rust source files
*.rs text eol=lf
*.toml text eol=lf

# Web source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Proto files
*.proto text eol=lf

# SQL migrations
*.sql text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.svg text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# macOS-specific
*.dylib binary

# Linux-specific
*.so binary
